> [!tag-siblings]- Сиблинги по тегам
> ```dataviewjs
> const tags = dv.current().tags
> if (!tags || tags.length === 0) {
>   dv.el("div", "Нет тегов", {})
> } else {
>   const pages = dv.pages().where(p =>
>     p.file.path !== dv.current().file.path &&
>     p.tags &&
>     p.tags.some(t => tags.includes(t))
>   )
>   const html = pages.map(p =>
>     `<a href="${p.file.path}" class="internal-link" style="
>       display: inline-block; padding: 4px 10px; margin: 3px;
>       border-radius: 12px; background: var(--interactive-accent);
>       color: var(--text-on-accent); font-size: 0.85em; text-decoration: none;
>     ">${p.file.name}</a>`
>   ).join("")
>   dv.el("div", html || "Нет совпадений", {cls: "dataview"})
> }
> ```

