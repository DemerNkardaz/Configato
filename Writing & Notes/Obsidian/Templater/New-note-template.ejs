<%*
let _fileTitle, _entityType, _status, _tagList, _aliasList, _body, _nameVariants, _pseudonyms

try {
  _fileTitle = await tp.system.prompt("Название")
  if (!_fileTitle) { new Notice("Шаблонизация отменена"); return }

  const sanitized = _fileTitle.replace(/[\\/:*?"<>|#^[\]]/g, " ").replace(/\s+/g, " ").trim()
  await tp.file.rename(sanitized)

  _entityType = await tp.system.suggester(
    ["📄 Пустая страница", "👩🏻‍🦳 Персонаж", "🗾 Локация", "🏳️ Государство/Империя", "🏙️ Город", "🏘️ Поселение", "🧝🏻‍♀️ Раса", "📅 Событие", "🏺 Артефакт", "🧊 Предмет", "🏹 Оружие", "🏢 Организация", "🌪️ Явление", "🧩 Прочее"],
    ["📄 Пустая страница", "👩🏻‍🦳 Персонаж", "🗾 Локация", "🏳️ Государство/Империя", "🏙️ Город", "🏘️ Поселение", "🧝🏻‍♀️ Раса", "📅 Событие", "🏺 Артефакт", "🧊 Предмет", "🏹 Оружие", "🏢 Организация", "🌪️ Явление", "🧩 Прочее"]
  )
  if (!_entityType) { new Notice("Шаблонизация отменена"); return }

  const templates = {
		"📄 Пустая страница":        ``,
    "👩🏻‍🦳 Персонаж":     `## Внешность\n\n## Характер\n\n## История\n\n## Роль в мире\n\n## Связи\n`,
    "🗾 Локация":      `## Описание\n\n## История\n\n## Обитатели\n\n## Значение\n`,
    "🏳️ Государство/Империя":  `## Описание\n\n## История\n\n## Правительство\n\n## Армия\n\n## Экономика\n\n## Культура\n\n## Известные личности\n`,
    "🏙️ Город":        `## Описание\n\n## История\n\n## Районы\n\n## Власть\n\n## Известные места\n\n## Известные личности\n`,
    "🏘️ Поселение":    `## Описание\n\n## История\n\n## Население\n\n## Особенности\n`,
    "🧝🏻‍♀️ Раса":         `## Внешность\n\n## Культура и традиции\n\n## История\n\n## Отношения с другими расами\n\n## Известные представители\n`,
    "📅 Событие":      `## Что произошло\n\n## Участники\n\n## Причины\n\n## Последствия\n`,
    "🏺 Артефакт":     `## Описание\n\n## Происхождение\n\n## Свойства\n\n## Текущее местонахождение\n\n## История владельцев\n`,
    "🧊 Предмет":      `## Описание\n\n## Происхождение\n\n## Свойства\n\n## Текущее местонахождение\n`,
    "🏹 Оружие":       `## Описание\n\n## Происхождение\n\n## Характеристики\n\n## История владельцев\n\n## Текущее местонахождение\n`,
    "🏢 Организация":  `## Описание\n\n## История\n\n## Структура\n\n## Цели и методы\n\n## Известные члены\n\n## Влияние\n`,
    "🌪️ Явление":      `## Описание\n\n## Природа и механизм\n\n## Проявления\n\n## Влияние на мир\n`,
    "🧩 Прочее":       `## Описание\n\n## Заметки\n`,
  }
  _body = templates[_entityType] ?? `## Описание\n\n## Заметки\n`

	if (_entityType === "👩🏻‍🦳 Персонаж") {
		const nameVariantsRaw = await tp.system.prompt("Варианты имени (через запятую, или пусто)", "")
		_nameVariants = nameVariantsRaw ? nameVariantsRaw.split(",").map(n => n.trim()) : []

		const pseudonymesRaw = await tp.system.prompt("Псевдонимы (через запятую, или пусто)", "")
		_pseudonyms = nameVariantsRaw ? pseudonymesRaw.split(",").map(n => n.trim()) : []
	}

	if (_entityType !== "пусто") {
		_status = await tp.system.suggester(
			["🌱 Набросок", "✍️ В работе", "✅ Готово"],
			["🌱 Набросок", "✍️ В работе", "✅ Готово"]
		)
		if (!_status) { new Notice("Шаблонизация отменена"); return }

		const tagsRaw = await tp.system.prompt("Теги через запятую (или пусто)", "")
		_tagList = tagsRaw ? tagsRaw.split(",").map(t => t.trim().replace(/\s+/g, "-")) : []

		const aliasesRaw = await tp.system.prompt("Псевдонимы/алиасы (через запятую)", "")
		_aliasList = aliasesRaw ? aliasesRaw.split(",").map(a => a.trim()) : []
	} else {
		_status = "🌱 Набросок"
		_tagList = []
		_aliasList = []
	}

  tR += `---
название: ${_fileTitle}
${_entityType === "👩🏻‍🦳 Персонаж" ? `имена:\n${_nameVariants.map(n => `  - ${n}`).join("\n")}` : ""}
${_entityType === "👩🏻‍🦳 Персонаж" ? `псевдонимы:\n${_pseudonyms.map(n => `  - ${n}`).join("\n")}` : ""}
тип: ${_entityType}
статус: ${_status}
создано: ${tp.date.now("YYYY-MM-DDThh:mm")}
обновлено: ${tp.date.now("YYYY-MM-DDThh:mm")}
tags: [${_tagList.join(", ")}]
aliases: [${_aliasList.join(", ")}]
---
# ${_fileTitle}

${_body}

---

> [!link-here]- На эту страницу ссылаются
> \`\`\`dataviewjs
> const current = dv.current().file.path
> const pages = dv.pages().where(p =>
>   p.file.outlinks.some(l => l.path === current)
> )
> const html = pages.map(p =>
>   \`<a href="\${p.file.path}" class="internal-link" style="
>     display: inline-block; padding: 4px 10px; margin: 3px;
>     border-radius: 12px; background: var(--interactive-accent);
>     color: var(--text-on-accent); font-size: 0.85em; text-decoration: none;
>   ">\${p.file.name}</a>\`
> ).join("")
> dv.el("div", html || "Нет ссылок", {cls: "dataview"})
> \`\`\`

> [!link-to]- Эта страница ссылается на
> \`\`\`dataviewjs
> const pages = dv.current().file.outlinks
> const html = pages.map(p =>
>   \`<a href="\${p.path}" class="internal-link" style="
>     display: inline-block; padding: 4px 10px; margin: 3px;
>     border-radius: 12px; background: var(--interactive-accent);
>     color: var(--text-on-accent); font-size: 0.85em; text-decoration: none;
>   ">\${p.path.split("/").pop().replace(".md", "")}</a>\`
> ).join("")
> dv.el("div", html || "Нет ссылок", {cls: "dataview"})
> \`\`\`

> [!tag-siblings]- Сиблинги по тегам
> \`\`\`dataviewjs
> const tags = dv.current().tags
> if (!tags || tags.length === 0) {
>   dv.el("div", "Нет тегов", {})
> } else {
>   const pages = dv.pages().where(p =>
>     p.file.path !== dv.current().file.path &&
>     p.tags &&
>     p.tags.some(t => tags.includes(t))
>   )
>   const html = pages.map(p =>
>     \`<a href="\${p.file.path}" class="internal-link" style="
>       display: inline-block; padding: 4px 10px; margin: 3px;
>       border-radius: 12px; background: var(--interactive-accent);
>       color: var(--text-on-accent); font-size: 0.85em; text-decoration: none;
>     ">\${p.file.name}</a>\`
>   ).join("")
>   dv.el("div", html || "Нет совпадений", {cls: "dataview"})
> }
> \`\`\`

---`

} catch(e) {
  new Notice("Шаблонизация отменена")
}
%>
